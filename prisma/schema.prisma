generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
  plan String @default("FREE")

  links     Link[]
  groups    Group[]
  settings  UserSettings?
}


model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  shortCode String   @unique
  clicks    Int      @default(0)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id])

  createdAt DateTime @default(now())
}

model Group {
  id                String   @id @default(cuid())
  name              String
  internalCode      String
  postAuto          Boolean  @default(false)
  intervalMinutes   Int      @default(30)
  randomMode        Boolean  @default(false)

  telegramToken     String   @default("")
  telegramChatId    String   @default("")

  whatsappMessage   String   @default("")

  shopeeAffiliateId String   @default("")
  shopeeSubId       String   @default("")

  postTitle         String   @default("")
  postPriceLabel    String   @default("")
  postCta           String   @default("")

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  links             Link[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserSettings {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  telegramBotToken         String   @default("")
  telegramChatId           String   @default("")
  telegramDefaultMessage   String   @default("")
  telegramSignature        String   @default("")

  whatsappGroupName        String   @default("")
  whatsappInviteLink       String   @default("")
  whatsappDefaultMessage   String   @default("")
  whatsappFooterCta        String   @default("")

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
